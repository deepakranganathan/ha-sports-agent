# Copy this to .env and fill in your values.
# Loaded automatically from the project root when sports_agent.py runs.

# Get a free API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
# NEWS_MAX_OUTPUT_TOKENS=4096
# NOTIFY_MAX_CHARS=1024

# URL of your HA instance (use local IP or FQDN)
HA_URL=http://192.168.1.x:8123

# Long-lived access token (Profile → Security → Long-Lived Access Tokens)
HA_TOKEN=eyJ0eXAiOiJKV1QiLCJhbGci...

# The HA notify service for your phone.
# Find yours in HA → Developer Tools → Services → search "notify"
# Usually: notify.mobile_app_<your_phone_name>
HA_NOTIFY_SERVICE=notify.mobile_app_deepak_phone

# Use a valid IANA timezone string
TIMEZONE=America/Chicago

# Optional: comma-separated team ids from teams.json (default: all enabled teams)
# TEAMS=liverpool-fc,india-cricket
